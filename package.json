{
  "name": "irl-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the IRL Engine — cryptographic pre-execution compliance rail",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["trading", "compliance", "ai", "fintech", "crypto"],
  "author": "MacroPulse <hello@macropulse.live>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GabrielGauss/irl-sdk-ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
